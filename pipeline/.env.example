# Copy to `.env` next to docker-compose.yml and fill in. Never commit `.env`.

# ╔══════════════════════════════════════════════════════════════════╗
# ║ DATA SOURCES — read-only. TWO databases on TWO separate RDS       ║
# ║ instances. Grant the collector SELECT on these only.              ║
# ╚══════════════════════════════════════════════════════════════════╝
# ① aws-luckyus-iehr-rw            →  database  luckyus_iehr
#      (roster + certification presence)            host env: IEHR_HOST
# ② aws-luckyus-opempefficiency-rw →  database  luckyus_opempefficiency
#      (clocked-in effective_hours for on-time calc) host env: OPEMPEFFICIENCY_HOST

# ── Credentials: ONE secret for username + password (shared by both DBs) ──
# AWS Secrets Manager secret holding ONLY the login. Host/port are NOT here.
#   { "username": "...", "password": "..." }
AWS_REGION=us-east-1
MYSQL_SECRET_NAME=collector/mysql
# No IAM role on the host? set these too:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── The TWO instance endpoints (REQUIRED — the ONLY source of host + port) ──
# Each database has its OWN host (and optionally its own port). Credentials above
# are reused for both. NO fallback for the host: if a *_HOST is unset the pipeline
# logs an error and exits. Fill in the real RDS endpoint FQDNs from your DBA team:
IEHR_HOST=aws-luckyus-iehr-rw.<...>.us-east-1.rds.amazonaws.com
OPEMPEFFICIENCY_HOST=aws-luckyus-opempefficiency-rw.<...>.us-east-1.rds.amazonaws.com
#
# Ports — the two instances MAY differ. Per-DB port precedence:
#   {DB}_PORT  >  inline `host:port` in {DB}_HOST  >  shared MYSQL_PORT  >  3306
# Leave unset if both use 3306. To set explicitly when they differ:
#   IEHR_PORT=3306
#   OPEMPEFFICIENCY_PORT=3307
# or inline:  OPEMPEFFICIENCY_HOST=aws-luckyus-opempefficiency-rw.<...>.rds.amazonaws.com:3307
# MYSQL_PORT=3306        # shared default applied to any DB without its own *_PORT

# ── Local-dev escape (optional) ────────────────────────────────────
# Skip Secrets Manager and pass the shared username/password directly (set
# MYSQL_USER to enable). Endpoints (host + port) STILL come only from the
# per-instance *_HOST / *_PORT vars above.
# MYSQL_USER=
# MYSQL_PASSWORD=

GITHUB_TOKEN=                          # repo-scope PAT, pushes public/data.json
GITHUB_REPO=xiangyuzeng/lkus-lso-ontime-dashboard
GITHUB_BRANCH=main
GITHUB_FILE_PATH=public/data.json

# Daily refresh time (the container schedules in this timezone):
DAILY_HOUR=6
DAILY_MINUTE=0
DAILY_TIMEZONE=UTC
