# Copy to `.env` next to docker-compose.yml and fill in. Never commit `.env`.

AWS_REGION=us-east-1
MYSQL_SECRET_NAME=collector/mysql      # AWS Secrets Manager secret (host/port/user/password)
IEHR_HOST=                             # iEHR RDS endpoint (per-DB host override)
OPEMPEFFICIENCY_HOST=                  # opempefficiency RDS endpoint (per-DB host override)

GITHUB_TOKEN=                          # repo-scope PAT, pushes public/data.json
GITHUB_REPO=xiangyuzeng/lkus-lso-ontime-dashboard
GITHUB_BRANCH=main
GITHUB_FILE_PATH=public/data.json

# Daily refresh time (the container schedules in this timezone):
DAILY_HOUR=6
DAILY_MINUTE=0
DAILY_TIMEZONE=UTC
